# Copy to .env for local dev and docker compose:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Ed25519 signing key (PEM or base64-encoded 32-byte seed)
SIGNING_PRIVATE_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Override config path inside the container (default: /app/config.json in Docker)
CONFIG_PATH=/app/config.json

# ── Database (opt-in) ─────────────────────────────────────────────────────────
# Leave DB_HOST unset to run without a database — the app works fine without it.
# Set DB_HOST to enable: persistent block cursor, escrow cache, and distributed
# leasing (required for horizontal scaling / multi-replica deployments).
#
# Running Postgres on your local machine and using docker:ha?
#   Use DB_HOST=host.docker.internal  (not localhost — containers can't reach the host via localhost)
#   Docker Desktop on macOS/Windows resolves this automatically.
#   On Linux, docker-compose.ha.yml maps it via extra_hosts: host-gateway.

DB_DIALECT=postgres
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=trustvc
DB_USER=trustvc
DB_PASSWORD=

# Connection pool (optional — defaults shown)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

# Distributed lease TTL in ms — set to at least 3x your pollIntervalMs (default 30 s)
DB_LEASE_TTL_MS=30000

# ── OpenTelemetry (opt-in) ────────────────────────────────────────────────────
# Set OTEL_ENABLED=true to activate traces, metrics, and log correlation.
# Requires a running OTLP collector (see telemetry/docker-compose.yml for local setup).

OTEL_ENABLED=false
OTEL_SERVICE_NAME=trustvc-webhook-events
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# For managed backends (Datadog, Honeycomb, Grafana Cloud, etc.):
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <your-token>
